  "pip_boundary": {
    "pip_supports": [
      "pic agent explain",
      "pic agent check",
      "pic demo installed-smoke",
      "pic demo bootstrap",
      "pic runtime step with bootstrapped demo files",
      "pic phase lab with bootstrapped Phase Lab files",
      "pic audit canonical-readiness",
      "pic snapshot list/show",
      "pic schema export",
      "Python SDK imports"
    ],
    "clone_required_for": [
