    "route_execution_requests",
    "agent_tasks",
    "provenance",
    "web_fetch_reports",
    "identity_verified",
    "nonce_ledger",
    "reasons"
  ],
  "schema_bundle_command": "uv run pic schema --all --output-dir schemas/generated"
}
